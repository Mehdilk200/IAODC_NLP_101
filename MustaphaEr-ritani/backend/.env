# Database
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=cv_screening

# Security (Unused but kept for config compatibility)
SECRET_KEY=dev_secret_key_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# App
APP_ENV=development
# allow common vite dev ports including new 5178
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:5177,http://localhost:5178,http://127.0.0.1:5178,http://127.0.0.1:5173

# NLP Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
